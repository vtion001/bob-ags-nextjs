# Authentication
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-min-32-characters

# Application URL
NEXTAUTH_URL=http://localhost:3000

# Laravel API URL (for migration to Laravel backend)
NEXT_PUBLIC_LARAVEL_API_URL=http://localhost:8000

# Optional: CallTrackingMetrics API Credentials
# Add these in the Settings page of the dashboard
# CTM_ACCESS_KEY=your_ctm_access_key
# CTM_SECRET_KEY=your_ctm_secret_key
# CTM_ACCOUNT_ID=your_account_id

# Optional: OpenRouter API Key for AI Analysis
# OPENROUTER_API_KEY=sk-xxx

# Optional: Vercel Postgres (when adding database support)
# DATABASE_URL=postgres://user:password@host/dbname

# Optional: Vercel KV (for caching/sessions)
# KV_URL=redis://xxx
# KV_REST_API_URL=https://xxx.vercel.app
# KV_REST_API_TOKEN=xxx
